<?xml version="1.0" encoding="utf-8"?>
<!--
    ScrollView is required because the coin icon rows can grow as counts increase,
    which can push lower controls (Calculate/Reset/Result) off-screen on small devices.
    fillViewport keeps the content stretched to full screen height when icon counts are low.
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <!-- Single direct child preserves all existing ConstraintLayout logic and IDs. -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/main_background"
        tools:context=".MainActivity">

    <TextView
        android:id="@+id/balance_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:fontFamily="sans-serif-black"
        android:text="@string/balance_default"
        android:textColor="@color/title_text"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Title -->
    <TextView
        android:id="@+id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:fontFamily="sans-serif-black"
        android:text="@string/main_title"
        android:textColor="@color/title_text"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/balance_text" />

    <!-- Mode Spinner -->
    <Spinner
        android:id="@+id/mode_spinner"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="24dp"
        android:background="@drawable/spinner_background"
        android:padding="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/title" />

    <!-- Coin Input Instructions -->
    <TextView
        android:id="@+id/instructions_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:fontFamily="sans-serif"
        android:text="@string/coin_instructions"
        android:textColor="@color/secondary_text"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/mode_spinner" />

    <!-- Coin Input Buttons (Horizontal Layout) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/coin_buttons_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/instructions_text">

        <!-- Quarter Button -->
        <ImageButton
            android:id="@+id/quarter_button"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@drawable/coin_button_background"
            android:contentDescription="@string/quarter_description"
            android:scaleType="centerInside"
            app:layout_constraintEnd_toStartOf="@id/dime_button"
            app:layout_constraintHorizontal_chainStyle="spread_inside"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/quarter" />

        <!-- Dime Button -->
        <ImageButton
            android:id="@+id/dime_button"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@drawable/coin_button_background"
            android:contentDescription="@string/dime_description"
            android:scaleType="centerInside"
            app:layout_constraintEnd_toStartOf="@id/nickel_button"
            app:layout_constraintStart_toEndOf="@id/quarter_button"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/dime" />

        <!-- Nickel Button -->
        <ImageButton
            android:id="@+id/nickel_button"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@drawable/coin_button_background"
            android:contentDescription="@string/nickel_description"
            android:scaleType="centerInside"
            app:layout_constraintEnd_toStartOf="@id/penny_button"
            app:layout_constraintStart_toEndOf="@id/dime_button"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/nickel" />

        <!-- Penny Button -->
        <ImageButton
            android:id="@+id/penny_button"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@drawable/coin_button_background"
            android:contentDescription="@string/penny_description"
            android:scaleType="centerInside"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/nickel_button"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/penny" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Lightweight host view for coin-drop animation. -->
    <ImageView
        android:id="@+id/coin_drop_animation_view"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="24dp"
        android:contentDescription="@null"
        android:scaleType="fitCenter"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/coin_buttons_layout"
        tools:srcCompat="@drawable/quarter" />

    <!-- Quarters Input -->
    <TextView
        android:id="@+id/quarters_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="20dp"
        android:fontFamily="sans-serif"
        android:text="@string/quarters_label"
        android:textColor="@color/primary_text"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/coin_buttons_layout" />

    <EditText
        android:id="@+id/quarters_input"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="24dp"
        android:background="@drawable/edit_text_background"
        android:hint="@string/quarters_hint"
        android:inputType="number"
        android:padding="12dp"
        android:textColor="@color/primary_text"
        android:textColorHint="@color/hint_text"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/quarters_label" />

    <HorizontalScrollView
        android:id="@+id/quarters_icons_scroll"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="24dp"
        android:overScrollMode="never"
        android:scrollbars="none"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/quarters_input">

        <LinearLayout
            android:id="@+id/quarters_icons_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal" />
    </HorizontalScrollView>

    <!-- Dimes Input -->
    <TextView
        android:id="@+id/dimes_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="16dp"
        android:fontFamily="sans-serif"
        android:text="@string/dimes_label"
        android:textColor="@color/primary_text"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/quarters_icons_scroll" />

    <EditText
        android:id="@+id/dimes_input"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="24dp"
        android:background="@drawable/edit_text_background"
        android:hint="@string/dimes_hint"
        android:inputType="number"
        android:padding="12dp"
        android:textColor="@color/primary_text"
        android:textColorHint="@color/hint_text"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/dimes_label" />

    <HorizontalScrollView
        android:id="@+id/dimes_icons_scroll"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="24dp"
        android:overScrollMode="never"
        android:scrollbars="none"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/dimes_input">

        <LinearLayout
            android:id="@+id/dimes_icons_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal" />
    </HorizontalScrollView>

    <!-- Nickels Input -->
    <TextView
        android:id="@+id/nickels_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="16dp"
        android:fontFamily="sans-serif"
        android:text="@string/nickels_label"
        android:textColor="@color/primary_text"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/dimes_icons_scroll" />

    <EditText
        android:id="@+id/nickels_input"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="24dp"
        android:background="@drawable/edit_text_background"
        android:hint="@string/nickels_hint"
        android:inputType="number"
        android:padding="12dp"
        android:textColor="@color/primary_text"
        android:textColorHint="@color/hint_text"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/nickels_label" />

    <HorizontalScrollView
        android:id="@+id/nickels_icons_scroll"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="24dp"
        android:overScrollMode="never"
        android:scrollbars="none"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/nickels_input">

        <LinearLayout
            android:id="@+id/nickels_icons_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal" />
    </HorizontalScrollView>

    <!-- Pennies Input -->
    <TextView
        android:id="@+id/pennies_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="16dp"
        android:fontFamily="sans-serif"
        android:text="@string/pennies_label"
        android:textColor="@color/primary_text"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/nickels_icons_scroll" />

    <EditText
        android:id="@+id/pennies_input"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="24dp"
        android:background="@drawable/edit_text_background"
        android:hint="@string/pennies_hint"
        android:inputType="number"
        android:padding="12dp"
        android:textColor="@color/primary_text"
        android:textColorHint="@color/hint_text"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/pennies_label" />

    <HorizontalScrollView
        android:id="@+id/pennies_icons_scroll"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="24dp"
        android:overScrollMode="never"
        android:scrollbars="none"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/pennies_input">

        <LinearLayout
            android:id="@+id/pennies_icons_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal" />
    </HorizontalScrollView>

    <!-- Calculate Button -->
    <Button
        android:id="@+id/calculate_button"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="24dp"
        android:backgroundTint="@color/button_background"
        android:text="@string/calculate_button"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        app:cornerRadius="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/pennies_icons_scroll" />

    <Button
        android:id="@+id/reset_button"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="24dp"
        android:backgroundTint="@color/button_background"
        android:text="@string/reset_button"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        app:cornerRadius="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/calculate_button" />

    <!--
        Overlay view for wizard spell animation.
        It is constrained to all sides of Calculate so it stays centered on top,
        while width/height are set in code from proportional screen sizing.
    -->
    <ImageView
        android:id="@+id/wizard_spell_animation_view"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:contentDescription="@null"
        android:elevation="8dp"
        android:scaleType="fitCenter"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/calculate_button"
        app:layout_constraintEnd_toEndOf="@id/calculate_button"
        app:layout_constraintStart_toStartOf="@id/calculate_button"
        app:layout_constraintTop_toTopOf="@id/calculate_button"
        tools:srcCompat="@drawable/wizardcat_money_spell" />

    <!-- Result Text View -->
    <TextView
        android:id="@+id/result_text"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="32dp"
        android:background="@drawable/result_background"
        android:fontFamily="sans-serif-black"
        android:gravity="center"
        android:padding="16dp"
        android:text="@string/result_placeholder"
        android:textColor="@color/result_text"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/reset_button" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>